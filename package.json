{
  "name": "@musetric/monorepo",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": "26.2.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach --all --parallel --interlaced run dev",
    "build:project": "yarn workspaces foreach --all --topological-dev --parallel --interlaced run build:project",
    "dev:desktop": "yarn build:project && yarn workspace @musetric/desktop dev:desktop",
    "build:desktop": "yarn build:project && yarn workspace @musetric/desktop build:desktop",
    "project:init": "yarn workspaces foreach --all --parallel --interlaced run project:init",
    "project:start": "yarn workspaces foreach --all --parallel --interlaced run project:start",
    "check:deps:security": "yarn npm audit --all --recursive --severity high",
    "check:deps:dupe": "yarn constraints && yarn dedupe --check",
    "check:dupe": "jscpd packages --config .jscpd.json",
    "fix:deps:dupe": "yarn constraints --fix && yarn && yarn dedupe",
    "check:unused": "knip",
    "check:editor": "editorconfig-checker",
    "check:format": "prettier --check .",
    "fix:format": "prettier . --write --list-different",
    "check:translations": "yarn workspaces foreach --all --parallel --interlaced run check:translations",
    "fix:translations": "yarn workspaces foreach --all --parallel --interlaced run fix:translations",
    "check:ts": "yarn workspaces foreach --all --parallel --interlaced run check:ts",
    "check:lint": "yarn workspaces foreach --all --parallel --interlaced run check:lint",
    "fix:lint": "yarn workspaces foreach --all --parallel --interlaced run fix:lint",
    "test": "yarn workspaces foreach --all --parallel --interlaced run test"
  },
  "devDependencies": {
    "editorconfig-checker": "catalog:",
    "jscpd": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:"
  },
  "resolutions": {
    "adm-zip": "^0.6.0",
    "onnxruntime-web": "patch:onnxruntime-web@npm%3A1.26.0#~/.yarn/patches/onnxruntime-web-npm-1.26.0-8c231f93bf.patch",
    "sharp": "^0.35.3"
  }
}
