{
  "name": "@musetric/eslint-config",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:project": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "peerDependencies": {
    "eslint": "10.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "catalog:",
    "@eslint/js": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "eslint-plugin-sonarjs": "catalog:",
    "jiti": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@types/estree": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
