{
  "name": "@musetric/backend-core",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/app.ts",
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./config": {
      "monorepo": "./src/common/config.ts",
      "types": "./dist/common/config.d.ts",
      "import": "./dist/common/config.js",
      "default": "./dist/common/config.js"
    }
  },
  "scripts": {
    "build:project": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "peerDependencies": {
    "@fastify/multipart": "9.4.0",
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@fastify/websocket": "11.2.0",
    "@musetric/ai": "workspace:*",
    "@musetric/api": "workspace:*",
    "@musetric/backend-db": "workspace:*",
    "@musetric/cqt": "workspace:*",
    "@musetric/fft": "workspace:*",
    "@musetric/toolkit": "workspace:*",
    "@musetric/utils": "workspace:*",
    "axios": "1.18.1",
    "fastify": "5.8.5",
    "fastify-sse-v2": "4.2.2",
    "fastify-type-provider-zod": "6.1.0",
    "onnxruntime-web": "1.26.0",
    "openapi-types": "12.1.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@fastify/multipart": "catalog:",
    "@fastify/static": "catalog:",
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@fastify/websocket": "catalog:",
    "@musetric/ai": "workspace:*",
    "@musetric/api": "workspace:*",
    "@musetric/backend-db": "workspace:*",
    "@musetric/cqt": "workspace:*",
    "@musetric/eslint-config": "workspace:*",
    "@musetric/fft": "workspace:*",
    "@musetric/toolkit": "workspace:*",
    "@musetric/utils": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "axios": "catalog:",
    "eslint": "catalog:",
    "fastify": "catalog:",
    "fastify-sse-v2": "catalog:",
    "fastify-type-provider-zod": "catalog:",
    "onnxruntime-web": "catalog:",
    "openapi-types": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
