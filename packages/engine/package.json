{
  "name": "@musetric/engine",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "peerDependencies": {
    "@musetric/api": "workspace:*",
    "@musetric/audio": "workspace:*",
    "@musetric/spectrogram": "workspace:*",
    "@musetric/utils": "workspace:*",
    "axios": "1.18.1",
    "immer": "11.1.4",
    "zod": "4.4.3",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@alexanderolsen/libsamplerate-js": "catalog:",
    "@musetric/api": "workspace:*",
    "@musetric/audio": "workspace:*",
    "@musetric/eslint-config": "workspace:*",
    "@musetric/fft": "workspace:*",
    "@musetric/spectrogram": "workspace:*",
    "@musetric/utils": "workspace:*",
    "@types/audioworklet": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "@webgpu/types": "catalog:",
    "axios": "catalog:",
    "eslint": "catalog:",
    "immer": "catalog:",
    "mediabunny": "catalog:",
    "signalsmith-stretch": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  }
}
