{
  "name": "@musetric/fft",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/index.es.ts",
      "types": "./dist/index.es.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./gpu": {
      "monorepo": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "node ./scripts/setup.ts",
    "project:build": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache",
    "fix:lint": "eslint . --fix --cache",
    "test": "vitest run",
    "bench": "node --import tsx ./scripts/bench.ts"
  },
  "peerDependencies": {
    "@musetric/resource-utils": "workspace:*"
  },
  "devDependencies": {
    "@musetric/eslint-config": "workspace:*",
    "@musetric/resource-utils": "workspace:*",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@webgpu/types": "catalog:",
    "eslint": "catalog:",
    "koffi": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
