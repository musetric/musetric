{
  "name": "@musetric/backend-db",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./migrations": {
      "monorepo": "./src/migrations/index.ts",
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js",
      "default": "./dist/migrations/index.js"
    }
  },
  "scripts": {
    "build:project": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "peerDependencies": {
    "@musetric/utils": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@musetric/eslint-config": "workspace:*",
    "@musetric/utils": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
