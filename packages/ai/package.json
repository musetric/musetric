{
  "name": "@musetric/ai",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./node": {
      "monorepo": "./src/index.node.ts",
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.js",
      "default": "./dist/index.node.js"
    }
  },
  "scripts": {
    "project:build": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
