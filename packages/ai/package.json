  },
  "dependencies": {
    "playwright": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@musetric/fft": "workspace:*",
    "@musetric/resource-utils": "workspace:*",
    "onnxruntime-web": "1.26.0"
  },
  "devDependencies": {
    "@musetric/eslint-config": "workspace:*",
    "@musetric/fft": "workspace:*",
    "@musetric/resource-utils": "workspace:*",
    "@types/node": "catalog:",
    "@webgpu/types": "catalog:",
    "eslint": "catalog:",
    "onnxruntime-web": "catalog:",
    "typescript": "catalog:"
  }
}
