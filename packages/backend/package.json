{
  "name": "@musetric/backend",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "yarn project:init && yarn build:browser && node --import tsx --watch src/index.ts",
    "build:project": "tsc --build && vite build",
    "build:browser": "vite build",
    "project:init": "node --import tsx ./scripts/init.js",
    "project:start": "node dist/index.js",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "dependencies": {
    "@fastify/multipart": "catalog:",
    "@fastify/static": "catalog:",
    "@fastify/swagger": "catalog:",
    "@fastify/swagger-ui": "catalog:",
    "@fastify/websocket": "catalog:",
    "@musetric/ai": "workspace:*",
    "@musetric/api": "workspace:*",
    "@musetric/backend-core": "workspace:*",
    "@musetric/backend-db": "workspace:*",
    "@musetric/cqt": "workspace:*",
    "@musetric/fft": "workspace:*",
    "@musetric/toolkit": "workspace:*",
    "@musetric/utils": "workspace:*",
    "axios": "catalog:",
    "fastify": "catalog:",
    "fastify-sse-v2": "catalog:",
    "fastify-type-provider-zod": "catalog:",
    "onnxruntime-web": "catalog:",
    "openapi-types": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "selfsigned": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@musetric/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
