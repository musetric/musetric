{
  "name": "@musetric/script",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "monorepo": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "project:build": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "devDependencies": {
    "@musetric/eslint-config": "workspace:*",
    "@resvg/resvg-js": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "png-to-ico": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
