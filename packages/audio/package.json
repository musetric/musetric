{
  "name": "@musetric/audio",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./es": {
      "monorepo": "./src/index.es.ts",
      "types": "./dist/index.es.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./decoder": {
      "monorepo": "./src/decoder/index.ts",
      "types": "./dist/decoder/index.d.ts",
      "import": "./dist/decoder/index.js",
      "default": "./dist/decoder/index.js"
    },
    "./player": {
      "monorepo": "./src/player/index.ts",
      "types": "./dist/player/index.d.ts",
      "import": "./dist/player/index.js",
      "default": "./dist/player/index.js"
    },
    "./recording": {
      "monorepo": "./src/recording/index.ts",
      "types": "./dist/recording/index.d.ts",
      "import": "./dist/recording/index.js",
      "default": "./dist/recording/index.js"
    },
    "./calibration": {
      "monorepo": "./src/calibration/index.ts",
      "types": "./dist/calibration/index.d.ts",
      "import": "./dist/calibration/index.js",
      "default": "./dist/calibration/index.js"
    },
    "./timeline": {
      "monorepo": "./src/timeline/index.ts",
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.js",
      "default": "./dist/timeline/index.js"
    },
    "./waveform": {
      "monorepo": "./src/waveform/index.ts",
      "types": "./dist/waveform/index.d.ts",
      "import": "./dist/waveform/index.js",
      "default": "./dist/waveform/index.js"
    }
  },
  "scripts": {
    "project:build": "tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache --cache-strategy content",
    "fix:lint": "eslint . --fix --cache --cache-strategy content"
  },
  "peerDependencies": {
    "@alexanderolsen/libsamplerate-js": "2.1.2",
    "@musetric/utils": "workspace:*",
    "mediabunny": "1.35.1",
    "signalsmith-stretch": "1.3.2"
  },
  "devDependencies": {
    "@alexanderolsen/libsamplerate-js": "catalog:",
    "@musetric/eslint-config": "workspace:*",
    "@musetric/utils": "workspace:*",
    "@types/audioworklet": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "@webgpu/types": "catalog:",
    "eslint": "catalog:",
    "mediabunny": "catalog:",
    "signalsmith-stretch": "catalog:",
    "typescript": "catalog:"
  }
}
