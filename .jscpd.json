{
  "threshold": 1.2,
  "reporters": ["console"],
  "minLines": 10,
  "minTokens": 80,
  "ignore": [
    "**/.git/**",
    "**/.yarn/**",
    "**/dist/**",
    "**/dist-browser/**",
    "**/build/**",
    "**/coverage/**",
